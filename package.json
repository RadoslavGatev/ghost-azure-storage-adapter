{
  "name": "ghost-azure-storage-adapter",
  "version": "0.1.2",
  "description": "Ghost storage adapter for Azure Blob Storage with managed identity and key-based auth support",
  "main": "AzureBlobStorageAdapter.js",
  "types": "AzureBlobStorageAdapter.d.ts",
  "exports": {
    ".": "./AzureBlobStorageAdapter.js",
    "./AzureImagesStorage": "./AzureImagesStorage.js",
    "./AzureMediaStorage": "./AzureMediaStorage.js",
    "./AzureFilesStorage": "./AzureFilesStorage.js"
  },
  "files": [
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ghost",
    "storage",
    "adapter",
    "azure",
    "blob",
    "ghost-storage"
  ],
  "author": "Radoslav Gatev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RadoslavGatev/ghost-azure-storage-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/RadoslavGatev/ghost-azure-storage-adapter/issues"
  },
  "homepage": "https://github.com/RadoslavGatev/ghost-azure-storage-adapter#readme",
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@azure/storage-blob": "^12.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
